{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://delegation.ai/schemas/harness.v1.schema.json",
  "title": "Delegation AI Harnessfile v1",
  "type": "object",
  "required": ["version", "id", "objective", "triggers", "executors", "outputs"],
  "properties": {
    "version": {
      "const": "delegation.ai/v1"
    },
    "id": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[a-zA-Z0-9][a-zA-Z0-9_.-]*$"
    },
    "name": {
      "type": "string"
    },
    "objective": {
      "type": "string",
      "minLength": 1
    },
    "triggers": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["type"],
        "properties": {
          "type": {
            "type": "string"
          },
          "cron": {
            "type": "string"
          }
        },
        "additionalProperties": true
      }
    },
    "owners": {
      "type": "object",
      "additionalProperties": true
    },
    "capability_packs": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "description", "capabilities"],
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "description": {
            "type": "string"
          },
          "capabilities": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string"
            }
          },
          "approval_required_for": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        },
        "additionalProperties": true
      }
    },
    "models": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "provider", "model", "role"],
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "provider": {
            "type": "string"
          },
          "adapter": {
            "type": "string"
          },
          "model": {
            "type": "string"
          },
          "role": {
            "type": "string"
          },
          "budget_usd": {
            "type": "number"
          }
        },
        "additionalProperties": true
      }
    },
    "agents": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "runtime", "autonomy_level"],
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "runtime": {
            "type": "string"
          },
          "model": {
            "type": "string"
          },
          "autonomy_level": {
            "type": "string",
            "enum": ["suggest", "draft", "act", "operate", "deploy"]
          },
          "capability_packs": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "promotion": {
            "type": "object",
            "additionalProperties": true
          }
        },
        "additionalProperties": true
      }
    },
    "executors": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "kind", "adapter"],
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "kind": {
            "type": "string"
          },
          "adapter": {
            "type": "string"
          },
          "model": {
            "type": "string"
          },
          "purpose": {
            "type": "string"
          }
        },
        "additionalProperties": true
      }
    },
    "context": {
      "type": "object",
      "additionalProperties": true
    },
    "policies": {
      "type": "object",
      "properties": {
        "permissions": {
          "type": "object",
          "properties": {
            "allowed_mcp_servers": {
              "type": "array",
              "items": {
                "type": "string",
                "minLength": 1
              }
            },
            "allowed_mcp_tools": {
              "type": "array",
              "items": {
                "type": "string",
                "minLength": 1
              }
            }
          },
          "additionalProperties": true
        }
      },
      "additionalProperties": true
    },
    "outputs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "oneOf": [
          {
            "type": "string"
          },
          {
            "type": "object",
            "required": ["type"],
            "properties": {
              "type": {
                "type": "string"
              }
            },
            "additionalProperties": true
          }
        ]
      }
    },
    "evals": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "type"],
        "properties": {
          "id": {
            "type": "string"
          },
          "type": {
            "type": "string"
          },
          "description": {
            "type": "string"
          }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
