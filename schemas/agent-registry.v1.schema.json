{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://delegation.ai/schemas/agent-registry.v1.schema.json",
  "title": "DelegationHQ Agent Passport Registry v1",
  "type": "object",
  "required": ["version", "agents"],
  "properties": {
    "version": {
      "const": "delegation.agent-registry/v1"
    },
    "agents": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "runtime_type"],
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1,
            "pattern": "^[a-zA-Z0-9][a-zA-Z0-9_.-]*$"
          },
          "name": {
            "type": "string"
          },
          "runtime_type": {
            "type": "string",
            "minLength": 1
          },
          "endpoint": {
            "type": "object",
            "properties": {
              "type": {
                "type": "string"
              },
              "value": {
                "type": "string"
              }
            },
            "additionalProperties": true
          },
          "command": {
            "type": "string"
          },
          "api_url": {
            "type": "string"
          },
          "model": {
            "type": "string"
          },
          "autonomy_level": {
            "type": "string",
            "enum": ["suggest", "draft", "act", "operate", "deploy"]
          },
          "risk_level": {
            "type": "string",
            "enum": ["low", "medium", "high", "critical"]
          },
          "capability_packs": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "capabilities": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "allowed_tools": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "allowed_data": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "required_approvals": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "expected_outputs": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "evidence_requirements": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "promotion_evals": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
