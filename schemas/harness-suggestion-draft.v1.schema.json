{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://delegation.ai/schemas/harness-suggestion-draft.v1.schema.json",
  "title": "Delegation AI Harness Suggestion Draft v1",
  "type": "object",
  "required": [
    "version",
    "goal",
    "draft_source",
    "provider",
    "model",
    "rationale",
    "manifest",
    "safety_notes",
    "validation_expectations"
  ],
  "properties": {
    "version": {
      "const": "delegation.ai/harness-suggestion-draft/v1"
    },
    "goal": {
      "type": "string",
      "minLength": 1
    },
    "draft_source": {
      "type": "string",
      "enum": ["model"]
    },
    "provider": {
      "type": "string",
      "enum": ["openai", "anthropic", "ollama", "local"]
    },
    "model": {
      "type": "string",
      "minLength": 1
    },
    "rationale": {
      "type": "string",
      "minLength": 1
    },
    "manifest": {
      "type": "object",
      "description": "Proposed Harnessfile. The deterministic Harnessfile validator remains authoritative.",
      "additionalProperties": true
    },
    "safety_notes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "validation_expectations": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  },
  "additionalProperties": false
}
