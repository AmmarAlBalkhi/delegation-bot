{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://delegation.ai/schemas/adapter-contract.v1.schema.json",
  "title": "Delegation AI Adapter Contract v1",
  "type": "object",
  "required": [
    "id",
    "kind",
    "description",
    "risk",
    "approval_required_for",
    "inputs",
    "outputs",
    "planned_event_types",
    "required_evidence"
  ],
  "properties": {
    "id": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[a-zA-Z0-9][a-zA-Z0-9_.-]*$"
    },
    "kind": {
      "type": "string",
      "enum": ["workflow", "ai_harness", "model_provider", "tool", "ml_model", "human"]
    },
    "description": {
      "type": "string",
      "minLength": 1
    },
    "risk": {
      "type": "string",
      "enum": ["low", "medium", "high"]
    },
    "approval_required_for": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "inputs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "outputs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "planned_event_types": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "required_evidence": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    }
  },
  "additionalProperties": false
}
